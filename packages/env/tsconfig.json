{
  "compilerOptions": {
    "module": "ESNext",         // Allows import.meta
    "moduleResolution": "Bundler", // Optimized for Vite/Modern Node
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],    // DOM allows "window" check to pass
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true
  }
}